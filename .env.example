# 复制为项目根目录（与 run.py 同级）的 .env 后按需修改（切勿提交含真实密钥的 .env）

# ── VLM（yunwu OpenAI 兼容网关 + Gemini）────────────────────────────
VLM_MOCK=0
VLM_API_KEY=your-api-key-here
VLM_API_BASE=https://yunwu.ai/v1
VLM_MODEL=gemini-3.1-flash-lite:stable

# ── NitroGen ─────────────────────────────────────────────────────
NITROGEN_MOCK=1
# mock 模式下默认关闭快通道 TTS（避免一直占麦）；实机可设 FAST_TTS=1
FAST_TTS=0

# 后端：mock | fast_api（action_fast_system HTTP）| zmq（旧 ZMQ serve）
# NITROGEN_BACKEND=fast_api
# NITROGEN_FAST_API_URL=http://localhost:8000
# NITROGEN_FAST_API_FPS=2.5
# NITROGEN_FAST_API_RESET_ON_START=1

# 是否把 NitroGen 操控/时间线注入 VLM（默认关，避免 mock 误导非赛车画面）
# VLM_NITROGEN_INPUT=1

# 实机 NitroGen（ZMQ，旧路径）：
# NITROGEN_MOCK=0
# NITROGEN_BACKEND=zmq
# NITROGEN_SERVER=tcp://localhost:5555

# 实机 NitroGen（action_fast_system，推荐）：
# 1. 按 action_fast_system/README.md 建立 SSH 隧道到远端 FastAPI
# 2. 配置：
# NITROGEN_MOCK=0
# NITROGEN_BACKEND=fast_api
# NITROGEN_FAST_API_URL=http://localhost:8000

# ── 可选：Claude 直连（VLM_PROVIDER=anthropic 时使用）──────────
# ANTHROPIC_API_KEY=
